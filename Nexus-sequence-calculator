// ══════════════════════════════════════════════
// JOURNAL HELPERS
// ══════════════════════════════════════════════
function setDir(btn) {
    btn.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on'); selectedDir = btn.dataset.v;
}
function setEmo(btn) {
    btn.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on'); selectedEmo = btn.dataset.v;
}
function setRules(btn) {
    btn.parentElement.querySelectorAll('button').forEach(b=>b.classList.remove('on'));
    btn.classList.add('on'); selectedRules = btn.dataset.v;
}

// Set today's date
document.getElementById('jDate').value = new Date().toISOString().split('T')[0];

function saveJournal() {
    const outcome = document.querySelector('input[name=jOutcome]:checked').value;
    const entry = {
        id: Date.now(),
        date: document.getElementById('jDate').value,
        time: document.getElementById('jTime').value,
        pair: document.getElementById('jPair').value,
        session: document.getElementById('jSession').value,
        direction: selectedDir,
        outcome,
        sweeps: +document.getElementById('jSweeps').value,
        tpHit: document.getElementById('jTPHit').value,
        rAchieved: +document.getElementById('jR').value,
        pnl: +document.getElementById('jPnL').value,
        sweepDepth: +document.getElementById('jSweepDepth').value,
        displacement: document.getElementById('jDisplacement').value,
        emotion: selectedEmo,
        rules: selectedRules,
        notes: document.getElementById('jNotes').value,
        screenshot: document.getElementById('jScreenshot').value
    };

    if (outcome === 'LOSS') entry.rAchieved = -Math.abs(entry.rAchieved || entry.sweeps + 1);
    if (outcome === 'BE') entry.rAchieved = 0;

    journal.unshift(entry);
    saveData();
    renderJournal();
    updateCount();
    toast('✅ Sequence saved!');
    resetJForm();
}

function resetJForm() {
    document.getElementById('jDate').value = new Date().toISOString().split('T')[0];
    document.getElementById('jTime').value = '09:00';
    document.getElementById('jR').value = '8';
    document.getElementById('jPnL').value = '0';
    document.getElementById('jSweepDepth').value = '0';
    document.getElementById('jNotes').value = '';
    document.getElementById('jScreenshot').value = '';
    document.getElementById('oc-w').checked = true;
    document.getElementById('jSweeps').value = '2';
    document.getElementById('jTPHit').value = 'TP1';
}

function saveData() {
    localStorage.setItem('nexus_journal', JSON.stringify(journal));
}

function updateCount() {
    document.getElementById('jCount').textContent = journal.length;
}

function deleteEntry(id) {
    journal = journal.filter(e => e.id !== id);
    saveData(); renderJournal(); updateCount();
    toast('🗑️ Entry deleted');
}

function confirmClearAll() {
    document.getElementById('modalTitle').textContent = '⚠️ Clear All Data?';
    document.getElementById('modalBody').innerHTML = `
        <p style="color:var(--t2);margin-bottom:16px">This will permanently delete all ${journal.length} journal entries. This cannot be undone.</p>
        <div style="display:flex;gap:10px;justify-content:flex-end">
            <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
            <button class="btn btn-red" onclick="clearAll()">🗑️ Delete Everything</button>
        </div>`;
    document.getElementById('modalOverlay').classList.add('show');
}

function clearAll() {
    journal = []; saveData(); renderJournal(); updateCount(); closeModal();
    toast('All data cleared');
}

function closeModal() { document.getElementById('modalOverlay').classList.remove('show'); }

// ══════════════════════════════════════════════
// RENDER JOURNAL TABLE
// ══════════════════════════════════════════════
function renderJournal() {
    updateCount();
    const wrap = document.getElementById('jTableWrap');
    if (journal.length === 0) {
        wrap.innerHTML = `<div class="empty-state"><div class="empty-icon">📓</div><p>No sequences logged yet.</p><p style="font-size:.75rem">Use the form on the left to record your first sequence.</p></div>`;
        return;
    }

    let html = `<table class="j-table"><thead><tr>
        <th>Date</th><th>Pair</th><th>Dir</th><th>Session</th><th>Sweeps</th>
        <th>Result</th><th>R</th><th>P&L</th><th>TP Hit</th><th>Emotion</th><th>Rules</th><th>Notes</th><th></th>
    </tr></thead><tbody>`;

    journal.forEach(e => {
        const ocCls = e.outcome === 'WIN' ? 'win-cell' : e.outcome === 'LOSS' ? 'loss-cell' : 'be-cell';
        const ocIcon = e.outcome === 'WIN' ? '✅' : e.outcome === 'LOSS' ? '❌' : '⏸';
        const dirIcon = e.direction === 'LONG' ? '🟢' : '🔴';
        const emoMap = {calm:'😌',anxious:'😰',fomo:'🤑',revenge:'😤',confident:'💪'};
        const rulesMap = {yes:'✅',partial:'⚠️',no:'❌'};

        html += `<tr>
            <td>${e.date}<br><span style="font-size:.7rem;color:var(--t3)">${e.time||''}</span></td>
            <td style="font-weight:600">${e.pair}</td>
            <td>${dirIcon}</td>
            <td style="font-size:.75rem">${e.session}</td>
            <td style="text-align:center;font-weight:600">${e.sweeps}</td>
            <td class="${ocCls}">${ocIcon} ${e.outcome}</td>
            <td class="${ocCls}" style="font-size:.95rem">${e.rAchieved > 0 ? '+' : ''}${e.rAchieved}R</td>
            <td class="${e.pnl >= 0 ? 'win-cell' : 'loss-cell'}">${e.pnl >= 0 ? '+' : ''}$${e.pnl}</td>
            <td style="font-size:.75rem">${e.tpHit}</td>
            <td>${emoMap[e.emotion]||'😌'}</td>
            <td>${rulesMap[e.rules]||'✅'}</td>
            <td class="notes-cell">${(e.notes||'').substring(0,60)}${(e.notes||'').length>60?'...':''}</td>
            <td><button class="del-btn" onclick="deleteEntry(${e.id})">✕</button></td>
        </tr>`;
    });

    html += '</tbody></table>';
    wrap.innerHTML = html;
}

// ══════════════════════════════════════════════
// EXPORT CSV
// ══════════════════════════════════════════════
function exportCSV() {
    if (journal.length === 0) { toast('No data to export'); return; }
    const headers = ['Date','Time','Pair','Session','Direction','Outcome','Sweeps','TP_Hit','R_Achieved','PnL','Sweep_Depth','Displacement','Emotion','Rules','Notes'];
    const rows = journal.map(e => [e.date,e.time,e.pair,e.session,e.direction,e.outcome,e.sweeps,e.tpHit,e.rAchieved,e.pnl,e.sweepDepth,e.displacement,e.emotion,e.rules,`"${(e.notes||'').replace(/"/g,'""')}"`]);
    const csv = [headers.join(','), ...rows.map(r=>r.join(','))].join('\n');
    const blob = new Blob([csv], {type:'text/csv'});
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = `nexus_journal_${new Date().toISOString().split('T')[0]}.csv`;
    a.click();
    toast('📤 CSV exported!');
}

// ══════════════════════════════════════════════
// ANALYTICS
// ══════════════════════════════════════════════
function renderAnalytics() {
    const data = journal;
    if (data.length === 0) {
        document.getElementById('aStats').innerHTML = '<div class="empty-state" style="grid-column:1/-1"><div class="empty-icon">📊</div><p>No data yet. Log sequences in the Journal tab first.</p></div>';
        ['aEquity','aSweep','aSession','aTP','aEmotion','aRules'].forEach(id => document.getElementById(id).innerHTML = '');
        return;
    }

    const wins = data.filter(e=>e.outcome==='WIN');
    const losses = data.filter(e=>e.outcome==='LOSS');
    const totalR = data.reduce((s,e)=>s+e.rAchieved,0);
    const totalPnL = data.reduce((s,e)=>s+e.pnl,0);
    const winRate = data.length>0 ? (wins.length/data.length*100) : 0;
    const avgR = data.length>0 ? totalR/data.length : 0;
    const avgWinR = wins.length>0 ? wins.reduce((s,e)=>s+e.rAchieved,0)/wins.length : 0;
    const avgLossR = losses.length>0 ? losses.reduce((s,e)=>s+Math.abs(e.rAchieved),0)/losses.length : 0;
    const expectancy = data.length>0 ? (winRate/100*avgWinR - (1-winRate/100)*avgLossR) : 0;
    const avgSweeps = data.length>0 ? data.reduce((s,e)=>s+e.sweeps,0)/data.length : 0;

    // Best & worst
    const bestR = data.reduce((m,e)=>Math.max(m,e.rAchieved),-Infinity);
    const worstR = data.reduce((m,e)=>Math.min(m,e.rAchieved),Infinity);

    // Streak
    let curStreak=0, maxWinStreak=0, maxLossStreak=0, tempStreak=0, lastType='';
    data.slice().reverse().forEach(e=>{
        if(e.outcome===lastType||lastType===''){
            tempStreak++;
        }else{
            if(lastType==='WIN') maxWinStreak=Math.max(maxWinStreak,tempStreak);
            if(lastType==='LOSS') maxLossStreak=Math.max(maxLossStreak,tempStreak);
            tempStreak=1;
        }
        lastType=e.outcome;
    });
    if(lastType==='WIN') maxWinStreak=Math.max(maxWinStreak,tempStreak);
    if(lastType==='LOSS') maxLossStreak=Math.max(maxLossStreak,tempStreak);

    // Rules compliance
    const rulesYes = data.filter(e=>e.rules==='yes').length;
    const rulesCompliance = data.length>0 ? rulesYes/data.length*100 : 0;

    // Stats row
    document.getElementById('aStats').innerHTML = `
        <div class="stat"><div class="st-label">Total Sequences</div><div class="st-val" style="color:var(--blue)">${data.length}</div></div>
        <div class="stat"><div class="st-label">Win Rate</div><div class="st-val" style="color:${winRate>=50?'var(--green)':'var(--red)'}">${winRate.toFixed(1)}%</div><div class="st-sub">${wins.length}W / ${losses.length}L</div></div>
        <div class="stat"><div class="st-label">Total R</div><div class="st-val" style="color:${totalR>=0?'var(--green)':'var(--red)'}">${totalR>=0?'+':''}${totalR.toFixed(1)}R</div></div>
        <div class="stat"><div class="st-label">Total P&L</div><div class="st-val" style="color:${totalPnL>=0?'var(--green)':'var(--red)'}">${totalPnL>=0?'+':''}$${totalPnL.toFixed(0)}</div></div>
        <div class="stat"><div class="st-label">Avg R/Seq</div><div class="st-val" style="color:${avgR>=0?'var(--green)':'var(--red)'}">${avgR>=0?'+':''}${avgR.toFixed(1)}R</div></div>
        <div class="stat"><div class="st-label">Expectancy</div><div class="st-val" style="color:${expectancy>=0?'var(--green)':'var(--red)'}">${expectancy>=0?'+':''}${expectancy.toFixed(2)}R</div></div>
        <div class="stat"><div class="st-label">Best Trade</div><div class="st-val" style="color:var(--green)">+${bestR.toFixed(1)}R</div></div>
        <div class="stat"><div class="st-label">Avg Sweeps</div><div class="st-val" style="color:var(--purple)">${avgSweeps.toFixed(1)}</div></div>
        <div class="stat"><div class="st-label">Rules ✅</div><div class="st-val" style="color:${rulesCompliance>=80?'var(--green)':'var(--orange)'}">${rulesCompliance.toFixed(0)}%</div></div>
    `;

    // Equity chart (P&L bars)
    const maxPnL = Math.max(...data.map(e=>Math.abs(e.pnl)), 1);
    document.getElementById('aEquity').innerHTML = data.slice().reverse().map((e, i) => {
        const h = Math.max(Math.abs(e.pnl) / maxPnL * 100, 6);
        const cls = e.pnl >= 0 ? 'pos' : 'neg';
        return `<div class="eq-bar ${cls}" style="height:${h}%" data-val="${e.date}: ${e.pnl>=0?'+':''}$${e.pnl} (${e.rAchieved>=0?'+':''}${e.rAchieved}R)"></div>`;
    }).join('');

    // Sweep analysis
    const sweepCounts = [0,0,0,0]; // 0,1,2,3 sweeps
    const sweepWins = [0,0,0,0];
    data.forEach(e=>{
        const s=Math.min(e.sweeps,3);
        sweepCounts[s]++;
        if(e.outcome==='WIN') sweepWins[s]++;
    });
    const avgSweepDepth = data.filter(e=>e.sweepDepth>0);
    const avgDepth = avgSweepDepth.length>0 ? avgSweepDepth.reduce((s,e)=>s+e.sweepDepth,0)/avgSweepDepth.length : 0;

    document.getElementById('aSweep').innerHTML = `
        <div style="margin-bottom:14px;font-size:.78rem;color:var(--t2)">Average sweep depth: <strong style="color:var(--purple)">${avgDepth.toFixed(1)} pips</strong> beyond SL</div>
        ${[0,1,2,3].map(i=>{
            const pct = sweepCounts[i]>0 ? sweepWins[i]/sweepCounts[i]*100 : 0;
            const labels = ['No sweeps (E1 win)','1 sweep (E2 win)','2 sweeps (E3 win)','All stopped (loss)'];
            const colors = ['var(--green)','var(--blue)','var(--purple)','var(--red)'];
            return `<div class="perf-bar-wrap">
                <div class="perf-bar-label"><span>${labels[i]}</span><span>${sweepCounts[i]} trades (${pct.toFixed(0)}% WR)</span></div>
                <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${data.length>0?sweepCounts[i]/data.length*100:0}%;background:${colors[i]}"></div></div>
            </div>`;
        }).join('')}`;

    // Session performance
    const sessions = ['London','New York','Overlap','Asian','Off-Hours'];
    document.getElementById('aSession').innerHTML = sessions.map(s=>{
        const sd = data.filter(e=>e.session===s);
        const sw = sd.filter(e=>e.outcome==='WIN').length;
        const wr = sd.length>0 ? sw/sd.length*100 : 0;
        const tr = sd.reduce((a,e)=>a+e.rAchieved,0);
        const col = wr>=60?'var(--green)':wr>=40?'var(--yellow)':'var(--red)';
        return `<div class="perf-bar-wrap">
            <div class="perf-bar-label"><span>${s} (${sd.length})</span><span style="color:${col}">${wr.toFixed(0)}% WR · ${tr>=0?'+':''}${tr.toFixed(1)}R</span></div>
            <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${Math.max(wr,2)}%;background:${col}"></div></div>
        </div>`;
    }).join('');

    // TP distribution
    const tps = ['TP1','TP2','TP3','TRAIL','MANUAL','NONE'];
    const tpCounts = tps.map(t=>data.filter(e=>e.tpHit===t).length);
    const tpMax = Math.max(...tpCounts,1);
    const tpColors = ['var(--green)','var(--cyan)','var(--gold)','var(--purple)','var(--blue)','var(--red)'];
    document.getElementById('aTP').innerHTML = tps.map((t,i)=>`
        <div class="perf-bar-wrap">
            <div class="perf-bar-label"><span>${t}</span><span>${tpCounts[i]} (${data.length>0?(tpCounts[i]/data.length*100).toFixed(0):0}%)</span></div>
            <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${tpCounts[i]/tpMax*100}%;background:${tpColors[i]}"></div></div>
        </div>`).join('');

    // Emotion correlation
    const emos = ['calm','confident','anxious','fomo','revenge'];
    const emoLabels = ['😌 Calm','💪 Confident','😰 Anxious','🤑 FOMO','😤 Revenge'];
    document.getElementById('aEmotion').innerHTML = emos.map((em,i)=>{
        const ed = data.filter(e=>e.emotion===em);
        const ew = ed.filter(e=>e.outcome==='WIN').length;
        const wr = ed.length>0 ? ew/ed.length*100 : 0;
        const er = ed.reduce((a,e)=>a+e.rAchieved,0);
        const col = wr>=60?'var(--green)':wr>=40?'var(--yellow)':'var(--red)';
        return `<div class="perf-bar-wrap">
            <div class="perf-bar-label"><span>${emoLabels[i]} (${ed.length})</span><span style="color:${col}">${wr.toFixed(0)}% WR · ${er>=0?'+':''}${er.toFixed(1)}R</span></div>
            <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${Math.max(wr,2)}%;background:${col}"></div></div>
        </div>`;
    }).join('') + `<div style="margin-top:12px;padding:10px 14px;background:rgba(139,92,246,.05);border-radius:8px;font-size:.75rem;color:var(--t2)">
        💡 <strong>Insight:</strong> Compare win rates when calm vs emotional. If calm trades win more, that's your signal to only trade when centered.
    </div>`;

    // Rules & streak
    const last20 = data.slice(0, 20);
    document.getElementById('aRules').innerHTML = `
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px">
            <div>
                <div style="font-size:.75rem;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Rules Compliance</div>
                <div class="perf-bar-wrap">
                    <div class="perf-bar-label"><span>✅ Followed</span><span>${rulesYes}/${data.length}</span></div>
                    <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${rulesCompliance}%;background:var(--green)"></div></div>
                </div>
                <div class="perf-bar-wrap">
                    <div class="perf-bar-label"><span>⚠️ Partial</span><span>${data.filter(e=>e.rules==='partial').length}</span></div>
                    <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${data.length>0?data.filter(e=>e.rules==='partial').length/data.length*100:0}%;background:var(--yellow)"></div></div>
                </div>
                <div class="perf-bar-wrap">
                    <div class="perf-bar-label"><span>❌ Broken</span><span>${data.filter(e=>e.rules==='no').length}</span></div>
                    <div class="perf-bar-track"><div class="perf-bar-fill" style="width:${data.length>0?data.filter(e=>e.rules==='no').length/data.length*100:0}%;background:var(--red)"></div></div>
                </div>
                <div style="margin-top:12px;font-size:.78rem;color:var(--t2)">
                    Win rate when rules followed: <strong style="color:var(--green)">${(()=>{
                        const rf=data.filter(e=>e.rules==='yes');
                        return rf.length>0?(rf.filter(e=>e.outcome==='WIN').length/rf.length*100).toFixed(0):0;
                    })()}%</strong><br>
                    Win rate when rules broken: <strong style="color:var(--red)">${(()=>{
                        const rb=data.filter(e=>e.rules==='no');
                        return rb.length>0?(rb.filter(e=>e.outcome==='WIN').length/rb.length*100).toFixed(0):0;
                    })()}%</strong>
                </div>
            </div>
            <div>
                <div style="font-size:.75rem;color:var(--t3);text-transform:uppercase;letter-spacing:1px;margin-bottom:8px">Last 20 Sequences</div>
                <div class="streak-dots">
                    ${last20.slice().reverse().map(e=>`<div class="streak-dot ${e.outcome==='WIN'?'w':e.outcome==='LOSS'?'l':'b'}" title="${e.date}: ${e.outcome} ${e.rAchieved}R"></div>`).join('')}
                </div>
                <div style="margin-top:12px;font-size:.78rem;color:var(--t2)">
                    🟢 = Win &nbsp; 🔴 = Loss &nbsp; 🟡 = B/E<br>
                    Best win streak: <strong style="color:var(--green)">${maxWinStreak}</strong> &nbsp;
                    Worst loss streak: <strong style="color:var(--red)">${maxLossStreak}</strong>
                </div>
            </div>
        </div>`;
}

