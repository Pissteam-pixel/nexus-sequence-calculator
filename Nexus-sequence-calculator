<!-- ═══════════════════════════════════════════════════
     JAVASCRIPT
     ═══════════════════════════════════════════════════ -->
<script>
// ══════════════════════════════════════════════
// GLOBAL STATE
// ══════════════════════════════════════════════
let journal = JSON.parse(localStorage.getItem('nexus_journal') || '[]');
let selectedDir = 'LONG';
let selectedEmo = 'calm';
let selectedRules = 'yes';

// ══════════════════════════════════════════════
// PAGE NAVIGATION
// ══════════════════════════════════════════════
function showPage(id, btn) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('page-' + id).classList.add('active');
    if (btn) btn.classList.add('active');
    if (id === 'analytics') renderAnalytics();
    if (id === 'journal') renderJournal();
}

// ══════════════════════════════════════════════
// CLOCK
// ══════════════════════════════════════════════
function updateClock() {
    const d = new Date();
    const utc = d.toUTCString().slice(17, 25);
    document.getElementById('clock').textContent = 'UTC ' + utc;
}
setInterval(updateClock, 1000); updateClock();

// ══════════════════════════════════════════════
// CALCULATOR
// ══════════════════════════════════════════════
function setInstr(btn) {
    btn.parentElement.querySelectorAll('button').forEach(b => b.classList.remove('on'));
    btn.classList.add('on');
    const v = btn.dataset.v;
    const pv = document.getElementById('cPipVal');
    const sl = document.getElementById('cSL');
    if (v === 'XAUUSD') { pv.value = 10; sl.value = 50; }
    else if (v === 'FOREX') { pv.value = 10; sl.value = 25; }
}

function runCalc() {
    const e1p = +document.getElementById('cE1').value;
    const e2p = +document.getElementById('cE2').value;
    const e3p = +document.getElementById('cE3').value;
    if (Math.abs(e1p + e2p + e3p - 100) > 0.1) {
        document.getElementById('allocWarn').style.display = 'block';
        document.getElementById('allocWarn').textContent = `⚠️ Total is ${e1p+e2p+e3p}% — must be 100%`;
        return;
    }
    document.getElementById('allocWarn').style.display = 'none';

    const bal = +document.getElementById('cBal').value;
    const pv = +document.getElementById('cPipVal').value;
    const budgetPct = +document.getElementById('cBudget').value;
    const sl = +document.getElementById('cSL').value;
    const tp1R = +document.getElementById('cTP1').value;
    const tp2R = +document.getElementById('cTP2').value;
    const tp3R = +document.getElementById('cTP3').value;
    const spw = +document.getElementById('cSeqWk').value;
    const wr = +document.getElementById('cWR').value / 100;
    const cur = document.getElementById('cCur').value;
    const sym = {USD:'$',EUR:'€',GBP:'£',NGN:'₦'}[cur] || '$';

    const totalRisk = bal * budgetPct / 100;
    const r1 = totalRisk * e1p / 100, r2 = totalRisk * e2p / 100, r3 = totalRisk * e3p / 100;
    const l1 = r1 / (sl * pv), l2 = r2 / (sl * pv), l3 = r3 / (sl * pv);
    const tp1P = sl * tp1R, tp2P = sl * tp2R, tp3P = sl * tp3R;

    // Scenarios
    const sA = { label: 'Win Entry 1 → TP1', cls: 'win', badge: 'BEST CASE', net: r1 * tp1R, cost: 0 };
    const sB = { label: '1 Sweep → Win E2', cls: 'win', badge: 'COMMON', net: r2 * tp1R - r1, cost: r1 };
    const sC = { label: `2 Sweeps → TP1 (${tp1R}R)`, cls: 'big', badge: `${tp1R}R`, net: r3 * tp1R - r1 - r2, cost: r1 + r2 };
    const sD = { label: `2 Sweeps → TP2 (${tp2R}R)`, cls: 'big', badge: `${tp2R}R 🔥`, net: r3 * tp2R - r1 - r2, cost: r1 + r2 };
    const sE = { label: `2 Sweeps → TP3 (${tp3R}R)`, cls: 'mega', badge: 'MONSTER 🎯', net: r3 * tp3R - r1 - r2, cost: r1 + r2 };
    const sF = { label: 'Full Sequence Loss', cls: 'loss', badge: 'MAX LOSS', net: -(r1 + r2 + r3), cost: r1 + r2 + r3 };
    const scenarios = [sA, sB, sC, sD, sE, sF];

    // Weekly
    const wins = Math.round(spw * wr), losses = spw - wins;
    const wkCons = wins * sC.net - losses * Math.abs(sF.net);
    const wkOpt = wins * (sC.net * .4 + sD.net * .6) - losses * Math.abs(sF.net);

    // Render
    document.getElementById('calcResults').style.display = 'block';

    document.getElementById('calcSummary').innerHTML = `<div class="sum-row">
        <div class="sum-card sc-blue anim"><div class="sl">Seq Budget</div><div class="sv">${sym}${totalRisk.toFixed(2)}</div><div class="ss">${budgetPct}% of ${sym}${bal.toLocaleString()}</div></div>
        <div class="sum-card sc-red anim"><div class="sl">Max Loss</div><div class="sv">-${sym}${totalRisk.toFixed(2)}</div><div class="ss">If all 3 stop</div></div>
        <div class="sum-card sc-green anim"><div class="sl">Best TP1 Win</div><div class="sv">+${sym}${sA.net.toFixed(2)}</div><div class="ss">+${(sA.net/bal*100).toFixed(1)}%</div></div>
        <div class="sum-card sc-gold anim"><div class="sl">Monster (TP3)</div><div class="sv">+${sym}${sE.net.toFixed(2)}</div><div class="ss">+${(sE.net/bal*100).toFixed(1)}%</div></div>
        <div class="sum-card sc-cyan anim"><div class="sl">Weekly Est.</div><div class="sv">${wkCons>=0?'+':''}${sym}${wkCons.toFixed(0)}</div><div class="ss">${(wkCons/bal*100).toFixed(1)}% conservative</div></div>
    </div>`;

    document.getElementById('calcTable').innerHTML = `<thead><tr><th>Entry</th><th>Role</th><th>Risk %</th><th>Risk ${sym}</th><th>Lot Size</th><th>SL</th></tr></thead><tbody>
        <tr><td><span class="entry-tag scout">🔵 E1</span></td><td>Scout</td><td>${(e1p*budgetPct/100).toFixed(2)}%</td><td>${sym}${r1.toFixed(2)}</td><td class="lot-hl" style="color:var(--blue)">${l1.toFixed(2)}</td><td>${sl} pips</td></tr>
        <tr><td><span class="entry-tag conf">🟣 E2</span></td><td>Confirmed</td><td>${(e2p*budgetPct/100).toFixed(2)}%</td><td>${sym}${r2.toFixed(2)}</td><td class="lot-hl" style="color:var(--purple)">${l2.toFixed(2)}</td><td>${sl} pips</td></tr>
        <tr><td><span class="entry-tag conv">🟡 E3</span></td><td>Conviction</td><td>${(e3p*budgetPct/100).toFixed(2)}%</td><td>${sym}${r3.toFixed(2)}</td><td class="lot-hl" style="color:var(--gold)">${l3.toFixed(2)}</td><td>${sl} pips</td></tr>
        <tr style="background:rgba(59,130,246,.03);font-weight:600"><td colspan="3">TOTAL</td><td>${sym}${totalRisk.toFixed(2)}</td><td>${(l1+l2+l3).toFixed(2)}</td><td></td></tr>
    </tbody>`;

    document.getElementById('calcLevels').innerHTML = `
        <div class="lv sl"><div class="ll">Stop Loss</div><div class="lval">${sl} pips</div><div class="lsub">1R</div></div>
        <div class="lv tp1"><div class="ll">TP1 (50%)</div><div class="lval">${tp1P.toFixed(0)} pips</div><div class="lsub">${tp1R}R</div></div>
        <div class="lv tp2"><div class="ll">TP2 (30%)</div><div class="lval">${tp2P.toFixed(0)} pips</div><div class="lsub">${tp2R}R</div></div>
        <div class="lv tp3"><div class="ll">TP3 (20%)</div><div class="lval">${tp3P.toFixed(0)} pips</div><div class="lsub">${tp3R}R</div></div>`;

    document.getElementById('calcScenarios').innerHTML = scenarios.map(s => `
        <div class="scen ${s.cls}"><div class="scen-top"><span class="scen-title">${s.label}</span><span class="scen-badge">${s.badge}</span></div>
        <div class="scen-val">${s.net>=0?'+':''}${sym}${s.net.toFixed(2)}</div>
        <div class="scen-detail"><span>${(s.net/bal*100).toFixed(2)}% of account</span></div></div>`).join('');

    // Projection
    let bC = bal, bO = bal, rows = '';
    for (let w = 1; w <= 4; w++) {
        bC += bC * wkCons / bal; bO += bO * wkOpt / bal;
        rows += `<div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:var(--bg1);border-radius:8px;margin-bottom:6px">
            <span style="font-size:.75rem;color:var(--t3);width:60px">Week ${w}</span>
            <span style="font-weight:600;min-width:100px">${sym}${bC.toFixed(0)}</span>
            <span style="font-weight:600;color:var(--cyan);min-width:100px">${sym}${bO.toFixed(0)}</span>
            <span style="margin-left:auto;font-size:.75rem;font-weight:600;padding:2px 8px;border-radius:6px;background:rgba(16,185,129,.08);color:var(--green)">+${((bO-bal)/bal*100).toFixed(1)}%</span>
        </div>`;
    }
    document.getElementById('calcProjection').innerHTML = `<div style="display:flex;gap:20px;margin-bottom:12px;font-size:.68rem;color:var(--t3);text-transform:uppercase;letter-spacing:1px;padding:0 14px"><span></span><span>📊 Conservative</span><span style="color:var(--cyan)">🚀 Optimistic</span></div>${rows}`;

    document.getElementById('calcResults').scrollIntoView({ behavior: 'smooth', block: 'start' });

    // Store for journal default
    window._lastCalc = { l1, l2, l3, r1, r2, r3, sl, tp1R, tp2R, tp3R, sym, totalRisk, bal };
}

